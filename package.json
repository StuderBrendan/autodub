{
  "name": "autodub",
  "version": "1.0.0",
  "description": "Dubbing app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dist": "electron-builder --win nsis",
    "dist:dir": "electron-builder --win dir"
  },
  "author": "Brendan Studer",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "yt-dlp-static": "^1.0.6"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.autodub.app",
    "productName": "AutoDub",
    "files": [
      "main.js",
      "src/**/*",
      "DubLibrary/**/*",
      "config.json",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/yt-dlp-static/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}